    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "fluent-ffmpeg": "^2.1.3",
    "generic-pool": "^3.9.0",
    "http-server": "^14.1.1",
    "jsonwebtoken": "^9.0.2",
    "ldapjs": "^3.0.7",
    "mssql": "^12.5.0",
    "multer": "^2.0.2",
    "node-notifier": "^10.0.1",
    "openai": "^5.20.1",
    "path": "^0.12.7",
    "pg": "^8.16.0",
    "pg-hstore": "^2.3.4",
    "pkg": "^5.8.1",
    "sequelize": "^6.37.5",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
