    "winston": "^3.17.0",
    "ws": "^8.18.3"
  },
  "scripts": {
    "dev": "nodemon app.js",
    "start": "node app.js",
    "build": "pkg app.js --targets node16-win-x64 --out-path dist"
  },
  "pkg": {
    "assets": [
      "node_modules/**/*",
      "config/**/*",
      "views/**/*",
      "public/**/*"
    ],
    "scripts": [
      "node_modules/pg/**/*.js",
      "node_modules/pg-hstore/**/*.js"
    ],
    "targets": [
      "node16-win-x64"
    ],
    "outputPath": "dist"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "nodemon": "^3.1.9",
    "sequelize-cli": "^6.6.3"
  }
}
